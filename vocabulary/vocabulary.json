{
  "vocabulary": "Elexon Insights API",
  "description": "Domain vocabulary extracted from the Elexon Insights Solution API OpenAPI specification",
  "tags": [
    {
      "term": "Balancing Mechanism Dynamic",
      "definition": "Dynamic data."
    },
    {
      "term": "Balancing Mechanism Physical",
      "definition": "Physical data consists of PN, QPN, MILS, &amp; MELS."
    },
    {
      "term": "Balancing Services Adjustment - Disaggregated",
      "definition": "Adjustment actions (DISBSAD) for a given settlement period, or summarised by settlement period over a time range."
    },
    {
      "term": "Balancing Services Adjustment - Net",
      "definition": "Net balancing services adjustment data (NETBSAD), provided as a time series or filtered to events."
    },
    {
      "term": "Bid-Offer",
      "definition": "Bid-offer data."
    },
    {
      "term": "Bid-Offer Acceptances",
      "definition": "Bid-offer acceptance data (BOALF)."
    },
    {
      "term": "BMRS Datasets",
      "definition": "Raw datasets as received from the National Grid, with associated metadata. The output in JSON format matches IRIS, and can be used interchangeably with IRIS output."
    },
    {
      "term": "Credit Default Notice",
      "definition": "Credit Default Notice data."
    },
    {
      "term": "Data Status",
      "definition": "The number of datapoints ingested for a dataset in a given period of time, grouped by settlement period."
    },
    {
      "term": "Demand",
      "definition": "GB electricity demand, including historic."
    },
    {
      "term": "Demand Forecast",
      "definition": "Current or historic demand forecasts."
    },
    {
      "term": "Generation",
      "definition": "GB electricity generation output, including historic."
    },
    {
      "term": "Generation Forecast",
      "definition": "Current or historic generation forecasts."
    },
    {
      "term": "Health Check",
      "definition": "Provides an endpoint to check the health of the Insights API service."
    },
    {
      "term": "Indicated Forecast",
      "definition": "Day-and-day-ahead indicated forecast, categorized as Indicated Generation (INDGEN), Indicated Demand (INDDEM), Imbalance (IMBALNGC) and Margin (MELNGC)."
    },
    {
      "term": "Indicative Imbalance Settlement",
      "definition": "Data related to the settlement process."
    },
    {
      "term": "Legacy",
      "definition": ""
    },
    {
      "term": "Load Shape",
      "definition": "Load shape period data and load shape totals data as calculated by the Load Shaping Service"
    },
    {
      "term": "Loss of Load Probability and De-rated Margin",
      "definition": "Loss of load probability and de-rated margin forecast data."
    },
    {
      "term": "Margin Forecast",
      "definition": "Generating Plant Operating Margin forecast data, including historical views of data by publish time or forecast date."
    },
    {
      "term": "Market Index",
      "definition": "Market Index prices filtered by time."
    },
    {
      "term": "Non-BM STOR",
      "definition": "Short Term Operating Reserves (STOR) data, provided as a time series or filtered to events."
    },
    {
      "term": "Non-BM Volumes",
      "definition": "Balancing services volume data, filtered by BM Unit and time range."
    },
    {
      "term": "Reference",
      "definition": "Reference data which can be used to filter other API requests."
    },
    {
      "term": "REMIT",
      "definition": "REMIT messages, including previous revisions."
    },
    {
      "term": "SAA Datasets",
      "definition": "Datasets received from the Settlement Administration Agent (SAA)"
    },
    {
      "term": "SO-SO Prices",
      "definition": "SO-SO Prices (SOSO) data, filtered by start time."
    },
    {
      "term": "Surplus Forecast",
      "definition": "Generating Plant Operating Surplus forecast data, including historical views of data by publish time or forecast date."
    },
    {
      "term": "System",
      "definition": "Transmission System data."
    },
    {
      "term": "System forecast",
      "definition": "Transmission System forecasts"
    },
    {
      "term": "Temperature",
      "definition": "Daily average & reference temperatures."
    }
  ],
